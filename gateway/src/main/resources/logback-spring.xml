<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 引入公共日志配置 -->
    <include resource="common-logback.xml"/>
    
    <!-- 应用名称 -->
    <property name="APP_NAME" value="gateway"/>
    
    <!-- Gateway 特定配置 -->
    <!--
    日志记录要点：
    1. 请求路由日志
    2. 认证/鉴权日志
    3. 限流日志
    4. 错误日志
    -->
    
    <!-- 路由日志 -->
    <logger name="org.springframework.cloud.gateway" level="INFO"/>
    <logger name="org.springframework.cloud.gateway.handler" level="DEBUG"/>
    
    <!-- 认证日志 -->
    <logger name="com.example.gateway.filter" level="INFO"/>
    
    <!-- 引入默认配置 -->
    <include resource="common-logback.xml"/>
</configuration>
