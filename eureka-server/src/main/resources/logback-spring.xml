<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 引入公共日志配置 -->
    <include resource="common-logback.xml"/>
    
    <!-- 应用名称 -->
    <property name="APP_NAME" value="eureka-server"/>
    
    <!-- Eureka Server 特定配置 -->
    <!--
    日志记录要点：
    1. 服务注册/注销日志
    2. 心跳日志
    3. 自我保护日志
    -->
    
    <!-- Eureka 日志 -->
    <logger name="com.netflix.eureka" level="INFO"/>
    <logger name="com.netflix.discovery" level="INFO"/>
    
    <!-- 引入默认配置 -->
    <include resource="common-logback.xml"/>
</configuration>
